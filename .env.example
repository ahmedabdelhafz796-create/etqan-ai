# ============================================================
#  ETQAN AI — Premium Trading Bookstore
#  Environment configuration. Copy this file to `.env.local`
#  and fill in real values. Never commit `.env.local`.
# ============================================================

# --- NOWPayments (crypto checkout) ---
# Get your API key from https://nowpayments.io  (Dashboard → Store Settings → API Keys)
NOWPAYMENTS_API_KEY=

# IPN (webhook) secret used to verify callback signatures.
NOWPAYMENTS_IPN_SECRET=

# Base API URL. Use the sandbox host while testing.
# Production: https://api.nowpayments.io/v1
# Sandbox:    https://api-sandbox.nowpayments.io/v1
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# Fiat currency the prices are denominated in.
NOWPAYMENTS_PRICE_CURRENCY=usd

# --- Public site config ---
# Canonical site URL (used for SEO metadata, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=https://etqan-ai.example.com

# Where the buyer is redirected after a successful / cancelled payment.
NEXT_PUBLIC_PAYMENT_SUCCESS_URL=https://etqan-ai.example.com/thank-you
NEXT_PUBLIC_PAYMENT_CANCEL_URL=https://etqan-ai.example.com/#store

# --- Placeholders you can override without touching code ---
# Direct checkout / gumroad / lemonsqueezy link (optional fallback).
NEXT_PUBLIC_PAYMENT_URL=PAYMENT_URL_PLACEHOLDER

# Telegram invite link (goes live August 1st, 2026).
NEXT_PUBLIC_TELEGRAM_URL=TELEGRAM_URL_PLACEHOLDER
