# NOWPayments dashboard -> Store Settings -> API keys
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
# NOWPayments dashboard -> Store Settings -> IPN secret key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret

# Public URL this backend + the static site are served from, no trailing slash.
# NOWPayments uses this to build success_url / cancel_url / ipn_callback_url.
BASE_URL=https://yourdomain.com

# Must match the price shown on checkout.html ($19)
PRICE_USD=19
